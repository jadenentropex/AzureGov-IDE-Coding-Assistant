      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aoaiName'))]",
        "[resourceId('Microsoft.Compute/virtualMachines', variables('vmName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName'))]",
      "name": "[guid(resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName')), variables('vmName'), 'metrics-publisher')]",
      "properties": {
        "roleDefinitionId": "[variables('roleMetricsPublisher')]",
        "principalId": "[reference(resourceId('Microsoft.Compute/virtualMachines', variables('vmName')), '2023-09-01', 'full').identity.principalId]",
