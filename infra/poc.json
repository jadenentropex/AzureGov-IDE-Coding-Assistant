    {
      "type": "Microsoft.Compute/virtualMachines/extensions",
      "apiVersion": "2023-09-01",
      "name": "[format('{0}/{1}', variables('vmName'), 'bootstrap')]",
      "location": "[parameters('location')]",
      "properties": {
        "publisher": "Microsoft.Compute",
        "type": "CustomScriptExtension",
        "typeHandlerVersion": "1.10",
        "autoUpgradeMinorVersion": true,
        "settings": {
          "fileUris": [
            "[parameters('bootstrapScriptUri')]"
          ],
          "commandToExecute": "[format('powershell -ExecutionPolicy Bypass -File bootstrap-devvm.ps1 -Endpoint \"{0}\" -DceIngest \"{1}\" -DcrId \"{2}\" -Stream \"{3}\" -RepoUrl \"{4}\" -AdminUser \"{5}\"', reference(resourceId('Microsoft.CognitiveServices/accounts', variables('aoaiName')), '2024-10-01').endpoint, reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName')), '2023-03-11').logsIngestion.endpoint, reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName')), '2023-03-11').immutableId, variables('streamName'), parameters('repoUrl'), parameters('adminUsername'))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts', variables('aoaiName'))]",
        "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]",
        "[resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName'))]",
        "[resourceId('Microsoft.Compute/virtualMachines', variables('vmName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.CognitiveServices/accounts', variables('aoaiName'))]",
