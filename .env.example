# Azure OpenAI - Azure US Government endpoint (note the .azure.us suffix, NOT .com)
AZURE_OPENAI_ENDPOINT=https://aoai-azgov-ide.openai.azure.us
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Break-glass ONLY (dev/smoke). Production uses keyless Entra ID (see below); leave blank there.
# Gov token audience for keyless auth: https://cognitiveservices.azure.us/.default
# Entra authority host:               https://login.microsoftonline.us
AZURE_OPENAI_API_KEY=

# CMMC posture: keep server-side state off. Responses API is called with store=false.
AZGOV_STORE=false
